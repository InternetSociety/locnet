{
  "name": "locnet-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:watch": "vite build --minify false --mode development --watch",
    "preview": "vite preview",
    "test": "npm run test:unittest && npm run test:types && npm run test:lint",
    "test:unittest": "vitest run",
    "test:types": "tsc -b",
    "test:lint": "eslint .",
    "format:prettier": "npx prettier --write .",
    "generate:api": "npx apigen-ts --no http://localhost:8000/openapi.json ./src/features/locnet/api-generated-client.ts && npx ts-to-zod ./src/features/locnet/api-generated-client.ts ./src/features/locnet/api-generated-zod.ts --skipValidation"
  },
  "dependencies": {
    "@noble/hashes": "2.2.0",
    "@redux-devtools/extension": "4.0.0",
    "@tanstack/react-table": "8.21.3",
    "@vanillaes/csv": "4.1.3",
    "canvg": "4.0.3",
    "dompdf.js": "2.0.0",
    "dompurify": "3.4.12",
    "immer": "11.1.15",
    "lodash-es": "4.18.1",
    "maplibre-gl": "6.0.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-icons": "5.7.0",
    "recharts": "3.10.0",
    "write-excel-file": "4.1.1",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/lodash-es": "4.17.12",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "4.3.2",
    "apigen-ts": "1.3.1",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "ts-to-zod": "5.1.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
